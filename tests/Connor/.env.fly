# ─────────────────────────────────────────────
# Geospatial Event Monitor
# ─────────────────────────────────────────────

# ── Grid ──────────────────────────────────────
# Cell size in decimal degrees (10°×10° = 648 cells worldwide)
GRID_DEGREES_LAT=10
GRID_DEGREES_LON=10

# ── Time window ───────────────────────────────
# How long (in minutes) a PositionEvent is retained in the buffer
TIME_WINDOW_MINUTES=5

# ── HTTP server ───────────────────────────────
BIND_ADDRESS=0.0.0.0:8080
METRICS_PATH=/metrics
QUERY_PATH=/query

# ── Lightning receiver (Blitzortung websocket) ─
LIGHTNING_WEBSOCKET_URL=wss://ws1.blitzortung.org/
# Seconds to wait before reconnecting after a dropped connection
LIGHTNING_RECONNECT_DELAY_SECS=5

# ── Flight receiver (OpenSky Network REST API) ─
FLIGHT_API_URL=https://opensky-network.org/api/states/all
# OpenSky allows one request per 10 s for anonymous access
FLIGHT_POLL_INTERVAL_SECS=10
OPENSKY_API_TOKEN=
# Optional bounding box — restrict the OpenSky query to a region of interest.
# Leave commented out to request the global feed.
# FLIGHT_BOUNDING_BOX=-90,90,-180,180

# ── Earthquake receiver (USGS GeoJSON) ────────
EARTHQUAKE_API_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_hour.geojson
EARTHQUAKE_POLL_INTERVAL_SECS=60
# Optional minimum magnitude filter.
EARTHQUAKE_MIN_MAGNITUDE=

# ── Vessel receiver (AIS websocket) ───────────
# Leave blank until you have a real provider endpoint and API key.
VESSEL_WEBSOCKET_URL=
VESSEL_API_KEY=
VESSEL_RECONNECT_DELAY_SECS=5
# Optional bounding box:
# VESSEL_BOUNDING_BOX=-90,90,-180,180

# ── ADS-B receiver (provider REST API) ────────
# Leave blank until you have a real provider endpoint and API key.
ADSB_API_URL=
ADSB_API_KEY=
ADSB_POLL_INTERVAL_SECS=10
# Optional bounding box:
# ADSB_BOUNDING_BOX=-90,90,-180,180

# ── Wikipedia edits receiver ──────────────────
WIKI_STREAM_URL=https://stream.wikimedia.org/v2/stream/recentchange
WIKI_GEODATA_API_URL=https://{host}/w/api.php
WIKI_RECONNECT_DELAY_SECS=5
WIKI_INCLUDE_BOT_EDITS=false

# ── Simulation fallback ───────────────────────
SIMULATE_EVENTS=false
SIMULATE_INTERVAL_SECS=2
